<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bubbly Nails | Premium Beauty Salon</title>
    <meta name="description" content="Welcome to Bubbly Nails - Elegance at your fingertips. Located in Fort Mill, SC.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Montserrat:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg-color: #fcf9f2;
            --bg-secondary: #ffffff;
            --text-primary: #1a1a1a;
            --text-secondary: #555555;
            --accent-gold: #c39b5b;
            --accent-gold-hover: #dabb78;

            --font-heading: 'Cormorant Garamond', serif;
            --font-body: 'Montserrat', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
            color: inherit;
            transition: all 0.3s ease;
        }

        /* Header Styles */
        .main-header {
            width: 100%;
            position: relative;
            z-index: 10;
            background: linear-gradient(to bottom, rgba(15, 16, 15, 0.95), rgba(15, 16, 15, 0));
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 40px;
            font-size: 12px;
            letter-spacing: 1px;
            color: var(--accent-gold);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .contact-info {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .award-badge {
            border: 1px solid var(--accent-gold);
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 10px;
            letter-spacing: 2px;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
        }

        .logo {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .logo-text {
            font-family: var(--font-heading);
            font-size: 28px;
            font-weight: 600;
            letter-spacing: 3px;
            line-height: 1;
        }

        .logo-subtext {
            font-family: var(--font-heading);
            font-size: 14px;
            font-style: italic;
            color: var(--accent-gold);
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 40px;
        }

        .nav-links a {
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 2px;
            color: var(--text-primary);
            position: relative;
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: var(--accent-gold);
        }

        .nav-links a.active::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 100%;
            height: 1px;
            background-color: var(--accent-gold);
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background-color: var(--accent-gold);
            color: #000;
            padding: 12px 24px;
            border-radius: 4px;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 1px;
            border: 1px solid var(--accent-gold);
        }

        .btn-primary:hover {
            background-color: var(--accent-gold-hover);
            border-color: var(--accent-gold-hover);
            transform: translateY(-2px);
        }

        .btn-outline {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background-color: transparent;
            color: #ffffff;
            padding: 12px 24px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 1px;
            border: 1px solid #ffffff;
        }

        .btn-outline:hover {
            border-color: var(--accent-gold);
            color: var(--accent-gold);
        }

        .address-bar {
            text-align: center;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            font-size: 11px;
            letter-spacing: 3px;
            color: var(--text-secondary);
            position: relative;
        }

        .address-bar::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 200px;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(195, 155, 91, 0.5), transparent);
        }

        .star-icon {
            color: var(--accent-gold);
            font-size: 14px;
        }

        /* Hero Section */
        .hero {
            display: flex;
            min-height: calc(100vh - 160px);
            padding: 40px;
            gap: 40px;
            align-items: center;
            background: linear-gradient(135deg, #1f1b14 0%, #0f0d0a 100%);
        }

        .hero-content {
            flex: 1;
            padding-left: 40px;
            max-width: 600px;
        }

        .subtitle {
            color: var(--accent-gold);
            font-size: 18px;
            font-weight: 600;
            letter-spacing: 4px;
            margin-bottom: 20px;
        }

        .title {
            font-family: var(--font-heading);
            font-size: 5rem;
            line-height: 1.1;
            margin-bottom: 30px;
            font-weight: 400;
            color: #ffffff;
        }

        .description {
            color: rgba(255, 255, 255, 0.9);
            font-size: 1.1rem;
            font-style: italic;
            font-family: var(--font-heading);
            margin-bottom: 40px;
            max-width: 90%;
            line-height: 1.8;
        }

        .hero-buttons {
            display: flex;
            gap: 20px;
        }

        .btn-primary.large,
        .btn-outline.large {
            padding: 16px 32px;
            font-size: 14px;
        }

        .hero-images {
            flex: 1.2;
            display: block;
            position: relative;
            height: 600px;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        }

        .image-wrapper {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
        }

        .left-image {
            animation: slide-1 10s infinite ease-in-out;
        }

        .right-image {
            animation: slide-2 10s infinite ease-in-out;
        }

        @keyframes slide-1 {

            0%,
            40% {
                opacity: 1;
            }

            50%,
            90% {
                opacity: 0;
            }

            100% {
                opacity: 1;
            }
        }

        @keyframes slide-2 {

            0%,
            40% {
                opacity: 0;
            }

            50%,
            90% {
                opacity: 1;
            }

            100% {
                opacity: 0;
            }
        }

        .image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.7s ease;
        }

        .image-wrapper:hover img {
            transform: scale(1.05);
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .title {
                font-size: 4rem;
            }

            .hero-images {
                height: 500px;
            }

            .nav-links {
                display: none;
            }
        }

        @media (max-width: 768px) {
            .hero {
                flex-direction: column;
                padding: 20px;
                min-height: auto;
            }

            .title {
                font-size: 3.5rem;
            }

            .hero-content {
                padding-left: 0;
                text-align: center;
                margin-bottom: 40px;
            }

            .description {
                margin: 0 auto 40px;
            }

            .hero-buttons {
                justify-content: center;
                flex-wrap: wrap;
            }

            .hero-images {
                width: 100%;
                height: 400px;
                flex: none;
                margin-top: 20px;
            }

            .top-bar {
                flex-direction: column;
                gap: 10px;
            }
        }

        @media (max-width: 480px) {
            .title {
                font-size: 2.5rem;
            }

            .hero-images {
                height: 300px;
            }

            .hero {
                padding: 20px 15px;
            }

            .about-section,
            .services-gallery-section,
            .gallery-section,
            .commitment-section,
            .contact-hours-section,
            .testimonials-section {
                padding: 40px 15px;
            }

            .btn-primary.large,
            .btn-outline.large {
                padding: 14px 20px;
                font-size: 13px;
            }
        }

        .about-section {
            max-width: 1200px;
            margin: 0 auto;
            padding: 80px 40px;
        }

        .about-header {
            text-align: center;
            margin-bottom: 60px;
        }

        .about-header h1 {
            font-size: 3.5rem;
            font-family: var(--font-heading);
            color: var(--accent-gold);
            margin-bottom: 10px;
            font-weight: 400;
        }

        .about-header .tagline {
            font-size: 1.2rem;
            color: var(--text-secondary);
            font-family: var(--font-heading);
            font-style: italic;
            letter-spacing: 2px;
        }

        .intro-text {
            font-size: 1.1rem;
            line-height: 1.8;
            color: var(--text-secondary);
            max-width: 800px;
            margin: 0 auto 60px;
            text-align: center;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
            margin-bottom: 60px;
        }

        .service-card {
            background: linear-gradient(145deg, #1a1b1a 0%, #0f100f 100%);
            padding: 40px 30px;
            border-radius: 8px;
            text-align: center;
            border: 1px solid rgba(195, 155, 91, 0.2);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
        }

        .service-card:hover {
            transform: translateY(-5px);
            border-color: rgba(195, 155, 91, 0.5);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.5);
        }

        .service-icon {
            font-size: 2.5rem;
            margin-bottom: 20px;
            display: block;
        }

        .service-card h3 {
            font-size: 1.5rem;
            color: #ffffff;
            font-family: var(--font-heading);
            margin-bottom: 15px;
            font-weight: 400;
        }

        .service-card p {
            color: rgba(255, 255, 255, 0.8);
            line-height: 1.7;
            font-size: 0.95rem;
        }

        .service-btn {
            display: inline-block;
            margin-top: 25px;
            padding: 10px 25px;
            border: 1px solid var(--accent-gold);
            color: var(--accent-gold);
            border-radius: 4px;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

        .service-btn:hover {
            background-color: var(--accent-gold);
            color: #0f100f;
            box-shadow: 0 5px 15px rgba(195, 155, 91, 0.4);
        }

        .location-cta {
            background: linear-gradient(135deg, #fff8dc 0%, #fbe490 100%);
            border: 4px solid #f9d857;
            padding: 50px;
            border-radius: 8px;
            text-align: center;
            margin-top: 60px;
            box-shadow: 0 0 20px rgba(251, 228, 144, 0.4);
            animation: yellow-glow 3s infinite alternate;
        }

        @keyframes yellow-glow {
            0% {
                box-shadow: 0 0 15px rgba(230, 200, 106, 0.4);
                border-color: #e6c86a;
            }

            100% {
                box-shadow: 0 0 40px rgba(251, 228, 144, 0.9);
                border-color: #ffffff;
            }
        }

        .location-cta h3 {
            font-family: var(--font-heading);
            font-size: 2.2rem;
            color: #8c6a21;
            margin-bottom: 15px;
            font-weight: 600;
        }

        .location-cta p {
            font-size: 1.1rem;
            color: #333333;
            margin-bottom: 30px;
            line-height: 1.8;
        }

        @media (max-width: 768px) {
            .about-header h1 {
                font-size: 2.5rem;
            }

            .services-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .location-cta {
                padding: 30px 20px;
            }
        }

        .commitment-section {
            padding: 80px 40px;
            background-color: var(--bg-color);
            position: relative;
        }

        .commitment-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 200px;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(195, 155, 91, 0.5), transparent);
        }

        .commitment-content {
            max-width: 800px;
            margin: 0 auto;
            background: linear-gradient(145deg, #1a1b1a 0%, #0f100f 100%);
            padding: 50px;
            border-radius: 12px;
            border: 1px solid rgba(195, 155, 91, 0.2);
            box-shadow: 0 0 20px rgba(195, 155, 91, 0.05);
            transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
            animation: pulse-glow 4s infinite alternate;
        }

        .commitment-content:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(195, 155, 91, 0.15);
            border-color: rgba(195, 155, 91, 0.5);
            animation-play-state: paused;
        }

        @keyframes pulse-glow {
            0% {
                box-shadow: 0 0 15px rgba(195, 155, 91, 0.05);
            }

            100% {
                box-shadow: 0 0 35px rgba(195, 155, 91, 0.15);
            }
        }

        .section-title {
            text-align: center;
            font-size: 1.2rem;
            color: var(--accent-gold);
            letter-spacing: 4px;
            margin-bottom: 10px;
            font-weight: 600;
        }

        .section-subtitle {
            text-align: center;
            font-size: 2.5rem;
            font-family: var(--font-heading);
            color: #ffffff;
            margin-bottom: 40px;
            font-weight: 400;
        }

        .guarantee-list {
            list-style: none;
            margin-bottom: 40px;
            padding: 0 20px;
        }

        .guarantee-list li {
            position: relative;
            padding-left: 30px;
            margin-bottom: 20px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 1.1rem;
            line-height: 1.6;
        }

        .guarantee-list li::before {
            content: '✧';
            position: absolute;
            left: 0;
            color: var(--accent-gold);
            display: inline-block;
            animation: star-twinkle 2s infinite alternate;
        }

        @keyframes star-twinkle {
            0% {
                opacity: 0.5;
                transform: scale(0.9);
            }

            100% {
                opacity: 1;
                transform: scale(1.2);
                text-shadow: 0 0 8px rgba(195, 155, 91, 0.8);
            }
        }

        .important-note {
            background: rgba(195, 155, 91, 0.05);
            border-left: 4px solid var(--accent-gold);
            padding: 20px 25px;
            color: #ffffff;
            font-style: italic;
            line-height: 1.6;
            border-radius: 0 8px 8px 0;
        }

        .important-note strong {
            color: var(--accent-gold);
            font-style: normal;
        }

        @media (max-width: 768px) {
            .commitment-content {
                padding: 30px 20px;
            }

            .section-subtitle {
                font-size: 2rem;
            }

            .guarantee-list {
                padding: 0;
            }
        }

        .services-gallery-section {
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
            padding: 100px 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .section-label {
            font-family: var(--font-body);
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--accent-gold);
            margin-bottom: 20px;
        }

        .main-heading {
            font-family: var(--font-heading);
            font-size: 4rem;
            font-weight: 400;
            line-height: 1.3;
            color: var(--text-primary);
            margin-bottom: 20px;
        }

        .quote-marks {
            font-family: var(--font-heading);
            font-size: 4.5rem;
            color: var(--accent-gold);
            vertical-align: middle;
        }

        .subheading {
            font-family: var(--font-body);
            font-size: 1.1rem;
            font-weight: 300;
            line-height: 1.7;
            color: var(--text-secondary);
            max-width: 600px;
            margin: 0 auto 30px;
        }

        .divider {
            width: 60px;
            height: 2px;
            background-color: var(--accent-gold);
            margin: 0 auto 50px;
        }

        .services-image-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            width: 100%;
        }

        .services-image-grid img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid var(--accent-gold);
            box-shadow: 0 0 10px rgba(195, 155, 91, 0.3);
            transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
        }

        .services-image-grid img:hover {
            transform: scale(1.05);
            border-color: #d4af37;
            box-shadow: 0 0 25px rgba(230, 200, 106, 0.6);
            z-index: 2;
            position: relative;
        }

        @media (max-width: 1024px) {
            .services-image-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 30px;
            }
        }

        @media (max-width: 768px) {
            .services-gallery-section {
                padding: 60px 20px;
            }

            .main-heading {
                font-size: 2.5rem;
            }

            .quote-marks {
                font-size: 3rem;
            }
        }

        @media (max-width: 480px) {
            .main-heading {
                font-size: 2rem;
            }

            .services-image-grid {
                grid-template-columns: 1fr;
            }
        }

        .gallery-section {
            padding: 100px 40px;
            text-align: center;
            background-color: var(--bg-color);
        }

        .gallery-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .gallery-section-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 30px;
            margin-bottom: 40px;
        }

        .gallery-section-title {
            font-family: var(--font-body);
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 3px;
            color: var(--accent-gold);
            text-transform: uppercase;
        }

        .gallery-line {
            width: 60px;
            height: 1px;
            background-color: var(--accent-gold);
        }

        .gallery-main-heading {
            font-family: var(--font-heading);
            font-size: 4.5rem;
            font-weight: 400;
            line-height: 1.2;
            color: var(--text-primary);
            margin-bottom: 30px;
        }

        .gallery-quote-left,
        .gallery-quote-right {
            font-size: 5rem;
            color: var(--accent-gold);
            vertical-align: middle;
        }

        .gallery-description {
            font-family: var(--font-body);
            font-size: 1.1rem;
            font-weight: 300;
            line-height: 1.8;
            color: var(--text-secondary);
            max-width: 700px;
            margin: 0 auto 60px;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
        }

        .gallery-grid img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border-radius: 4px;
            border: 2px solid var(--accent-gold);
            box-shadow: 0 0 10px rgba(195, 155, 91, 0.3);
            transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        }

        .gallery-grid img:hover {
            transform: scale(1.03);
            z-index: 2;
            position: relative;
            border-color: #d4af37;
            box-shadow: 0 0 25px rgba(230, 200, 106, 0.6);
        }

        @media (max-width: 1024px) {
            .gallery-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @media (max-width: 768px) {
            .gallery-section {
                padding: 60px 20px;
            }

            .gallery-section-header {
                gap: 20px;
            }

            .gallery-section-title {
                font-size: 12px;
                letter-spacing: 2px;
            }

            .gallery-line {
                width: 40px;
            }

            .gallery-main-heading {
                font-size: 3rem;
            }

            .gallery-quote-left,
            .gallery-quote-right {
                font-size: 3.5rem;
            }

            .gallery-description {
                font-size: 1rem;
            }

            .gallery-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 480px) {
            .gallery-main-heading {
                font-size: 2.5rem;
            }

            .gallery-quote-left,
            .gallery-quote-right {
                font-size: 3rem;
            }
        }

        /* Footer */
        .site-footer {
            background: linear-gradient(180deg, #fffcf5 0%, #fceba2 100%);
            padding: 60px 20px 30px;
            border-top: 2px solid var(--accent-gold);
            box-shadow: 0 -5px 20px rgba(195, 155, 91, 0.2);
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 30px;
        }

        .footer-logo {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .footer-info p {
            color: var(--text-secondary);
            margin-bottom: 5px;
            font-size: 1rem;
            letter-spacing: 1px;
        }

        .footer-social {
            display: flex;
            gap: 20px;
        }

        .footer-social a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            border: 2px solid var(--accent-gold);
            color: var(--accent-gold);
            box-shadow: 0 0 10px rgba(195, 155, 91, 0.4);
            transition: all 0.3s ease;
        }

        .footer-social a:hover {
            border-color: #d4af37;
            color: #d4af37;
            transform: translateY(-3px);
            box-shadow: 0 0 20px rgba(230, 200, 106, 0.8);
        }

        .footer-copyright {
